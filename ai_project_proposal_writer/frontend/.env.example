# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Your Supabase project URL (e.g., https://your-project.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase Anon/Public Key (found in Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# BACKEND API URL
# ============================================
# Development: Local backend server
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Production: Replace with your deployed backend URL (e.g., Hugging Face Spaces)
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.hf.space
