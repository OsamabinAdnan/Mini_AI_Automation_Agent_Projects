# Multi-Provider Configuration
# Uncomment and set the API keys for the providers you want to use

# Groq Configuration
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter Configuration
OPENROUTER_API_KEY=your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Qwen Configuration
QWEN_API_KEY=your-qwen-key-here
QWEN_BASE_URL=https://portal.qwen.ai/v1
QWEN_MODEL=qwen3-coder-plus

# Cohere Configuration
COHERE_API_KEY=your-cohere-key-here
COHERE_BASE_URL=https://api.cohere.ai/v1
COHERE_MODEL=command-a-03-2025

# The system will try providers in the order they are configured
# If one fails, it will automatically try the next available provider